# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# CocoaPods — vendor dependencies, never commit
ios/Pods/
macos/Pods/

# Flutter plugins file (auto-generated)
.flutter-plugins

# iOS build environment — may contain local machine paths
ios/Flutter/flutter_export_environment.sh

# xcworkspace inside Pods (generated)
ios/Pods/**/*.xcworkspace

# Sensitive / environment-specific
*.env
*.env.local
